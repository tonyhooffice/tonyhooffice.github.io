                <button id="tabBtn3" onclick="toggleColumn(3)" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all shadow-sm bg-slate-50 text-slate-400 hover:text-slate-600 border border-slate-200/40">
                    Tab C
                </button>
            </div>

            <!-- Settings and Home Buttons (Right) (Requirement 3c) -->
            <div class="flex items-center gap-2">
                <!-- Setting Button (Typical cog SVG icon) -->
                <button onclick="toggleSettings(true)" class="p-2.5 text-slate-600 hover:text-slate-900 bg-slate-50 hover:bg-slate-100 rounded-xl border border-slate-200/60 transition-all shadow-sm" title="Webpage Settings">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.43l-1.003.828c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.43l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.991l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                </button>
                
                <!-- Home Button (Typical home SVG icon) -->
                <a id="homeLink" href="#" target="_blank" class="p-2.5 text-slate-600 hover:text-slate-900 bg-slate-50 hover:bg-slate-100 rounded-xl border border-slate-200/60 transition-all shadow-sm" title="Go Home">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                    </svg>
                </a>
            </div>
        </div>
    </header>

    <!-- Synchronized Text Grid Rows Viewport (Requirement 3f) -->
    <!-- Placing rows inside a single outer scrollable container guarantees 100% synchronized vertical scrolling -->
    <main class="flex-1 overflow-y-auto w-full">
        <div class="max-w-7xl mx-auto px-4 py-4">
            <div id="tableBody" class="flex flex-col gap-0.5 rounded-2xl overflow-hidden border border-slate-200/60 shadow-sm sync-bg">
                <!-- Dynamically populated via sheets -->
            </div>
        </div>
    </main>

    <!-- Slide-over Settings Customization Panel (Requirement 3d) -->
    <div id="settingsOverlay" class="fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 flex justify-end">
        <div id="settingsContent" class="bg-white w-full max-w-md h-full shadow-2xl p-6 flex flex-col justify-between translate-x-full transition-transform duration-300">
            
            <div class="overflow-y-auto flex-1 pr-1">
                <div class="flex items-center justify-between pb-4 border-b border-slate-100 mb-6">
                    <!-- Title block left blank (Requirement 3) -->
                    <h3 class="text-lg font-bold text-slate-900 flex items-center gap-2"></h3>
                    <button onclick="toggleSettings(false)" class="p-1.5 hover:bg-slate-100 rounded-lg text-slate-400 hover:text-slate-600 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <!-- Webpage Color Setting (Requirement 3d - i; label left blank as per Requirement 3) -->
                <div class="mb-6 bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2"></label>
                    <div id="bgColorContainer" class="flex gap-2">
                        <!-- Color buttons dynamically added -->
                    </div>
                </div>

                <!-- Column Style Settings (Requirement 3d - ii, iii, iv) -->
                <div class="space-y-6">
                    <!-- Column 1 Customizations -->
                    <div class="p-4 rounded-xl border border-slate-100 bg-white shadow-sm space-y-4">
                        <div class="flex items-center gap-2 pb-2 border-b border-slate-100">
                            <span class="w-2.5 h-2.5 rounded-full bg-indigo-500"></span>
                            <h4 id="settingTitle1" class="font-bold text-slate-800 text-sm"></h4>
                        </div>
                        
                        <!-- Font Color selection -->
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase mb-1">Font Color</label>
                            <div id="col1Colors" class="flex gap-1.5"></div>
                        </div>

                        <!-- Font Family selection -->
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase mb-1">Font Type</label>
