                        </div>

                        <!-- Font Size selection -->
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="block text-[11px] font-bold text-slate-400 uppercase">Font Size</label>
                                <span id="col1SizeVal" class="text-xs font-semibold text-slate-600">16px</span>
                            </div>
                            <input id="col1SizeRange" type="range" min="10" max="26" step="1" value="16" oninput="updateFontSize(1, this.value)" class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-indigo-600">
                        </div>
                    </div>

                    <!-- Column 2 Customizations -->
                    <div class="p-4 rounded-xl border border-slate-100 bg-white shadow-sm space-y-4">
                        <div class="flex items-center gap-2 pb-2 border-b border-slate-100">
                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
                            <h4 id="settingTitle2" class="font-bold text-slate-800 text-sm"></h4>
                        </div>
                        
                        <!-- Font Color selection -->
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase mb-1">Font Color</label>
                            <div id="col2Colors" class="flex gap-1.5"></div>
                        </div>

                        <!-- Font Family selection -->
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase mb-1">Font Type</label>
                            <select id="col2FontSelect" onchange="updateFont(2, this.value)" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-xs focus:ring-2 focus:ring-emerald-500 focus:outline-none"></select>
                        </div>

                        <!-- Font Size selection -->
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="block text-[11px] font-bold text-slate-400 uppercase">Font Size</label>
                                <span id="col2SizeVal" class="text-xs font-semibold text-slate-600">16px</span>
                            </div>
                            <input id="col2SizeRange" type="range" min="10" max="26" step="1" value="16" oninput="updateFontSize(2, this.value)" class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-emerald-600">
                        </div>
                    </div>

                    <!-- Column 3 Customizations -->
                    <div class="p-4 rounded-xl border border-slate-100 bg-white shadow-sm space-y-4">
                        <div class="flex items-center gap-2 pb-2 border-b border-slate-100">
                            <span class="w-2.5 h-2.5 rounded-full bg-purple-500"></span>
                            <h4 id="settingTitle3" class="font-bold text-slate-800 text-sm"></h4>
                        </div>
                        
                        <!-- Font Color selection -->
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase mb-1">Font Color</label>
                            <div id="col3Colors" class="flex gap-1.5"></div>
                        </div>

                        <!-- Font Family selection -->
                        <div>
                            <label class="block text-[11px] font-bold text-slate-400 uppercase mb-1">Font Type</label>
                            <select id="col3FontSelect" onchange="updateFont(3, this.value)" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-xs focus:ring-2 focus:ring-purple-500 focus:outline-none"></select>
                        </div>

                        <!-- Font Size selection -->
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="block text-[11px] font-bold text-slate-400 uppercase">Font Size</label>
                                <span id="col3SizeVal" class="text-xs font-semibold text-slate-600">16px</span>
                            </div>
                            <input id="col3SizeRange" type="range" min="10" max="26" step="1" value="16" oninput="updateFontSize(3, this.value)" class="w-full h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-purple-600">
                        </div>
                    </div>
                </div>
            </div>

            <!-- "Apply & Save Changes" button has been removed (Requirement 4) -->
        </div>
    </div>

    <!-- Core Interactive Client Pipeline Logic -->
    <script>
        // Target Sheet pointer location (Sheet Alpha)
        const MASTER_SHEET_CSV = "https://docs.google.com/spreadsheets/d/1tp8aCnchL3QIJiZMKAduJJvehSNG2vIJ2Jfnx7qcs-Q/export?format=csv";

        // Application State State-machine
        let appState = {
            title: "",
            homeUrl: "",
            topBarContents: ["", "", ""],
            tabLabels: ["", "", ""],
            bgColors: ["#ffffff", "#f8fafc", "#f1f5f9"],
            fontColors: ["#000000", "#000000", "#000000"], // Set of available color values
            selectedFontColors: ["#000000", "#000000", "#000000"], // Initial active color value mapping for columns 1, 2, and 3
            columnFonts: [
                ["Inter", "Helvetica", "Georgia"],
                ["Roboto", "Arial", "Courier New"],
                ["System", "Verdana", "Times New Roman"]
            ],
            tableRows: [],
            activeColumns: [1, 2] // Default collapse Column 3 / C (Requirement 5)
        };

        // Utility to convert shared sheet link to immediate raw CSV export format
        function getCsvExportUrl(googleSheetUrl) {
            if (!googleSheetUrl) return "";
            try {
                // Extracts spreadsheet ID
                const matchId = googleSheetUrl.match(/\/d\/([a-zA-Z0-9-_]+)/);
                if (matchId && matchId[1]) {
                    return `https://docs.google.com/spreadsheets/d/${matchId[1]}/export?format=csv`;
                }
            } catch (err) {
                console.error("Invalid URL formatting from Sheet pointer:", err);
            }
            return googleSheetUrl;
        }

        // Custom parser to robustly split CSV data cells even when containing commas
        function parseCSVData(rawText) {
            let entries = [];
            let row = [""];
            let insideQuotes = false;

            for (let idx = 0; idx < rawText.length; idx++) {
                let char = rawText[idx];
                let peek = rawText[idx + 1];

                if (char === '"') {
                    if (insideQuotes && peek === '"') {
                        row[row.length - 1] += '"';
                        idx++;
                    } else {
                        insideQuotes = !insideQuotes;
                    }
                } else if (char === ',' && !insideQuotes) {
                    row.push('');
                } else if ((char === '\r' || char === '\n') && !insideQuotes) {
                    if (char === '\r' && peek === '\n') {
                        idx++;
                    }
                    entries.push(row.map(cell => cell.trim().replace(/^"|"$/g, '').replace(/""/g, '"')));
                    row = [""];
                } else {
                    row[row.length - 1] += char;
                }
            }
            if (row.length > 1 || row[0] !== '') {
                entries.push(row.map(cell => cell.trim().replace(/^"|"$/g, '').replace(/""/g, '"')));
            }
            return entries;
        }

        // Standard dynamic fetch implementation
        async function runPipeline() {
            const statusEl = document.getElementById("loaderStatus");
            try {
                // Step 1: Read the index pointer from Sheet Alpha
                statusEl.innerText = "Connecting to Sheet Alpha index...";
                const responseAlpha = await fetch(MASTER_SHEET_CSV);
                if (!responseAlpha.ok) throw new Error("Could not fetch the Master registry Sheet.");
                
                const csvTextAlpha = await responseAlpha.text();
                const matrixAlpha = parseCSVData(csvTextAlpha);
                
                if (!matrixAlpha || !matrixAlpha[0] || !matrixAlpha[0][0]) {
                    throw new Error("Unable to read URL from cell A1 of Sheet Alpha.");
                }

                const targetSheetRawUrl = matrixAlpha[0][0];
                statusEl.innerText = "Extracting URL pointing to Sheet Beta...";
                const targetSheetCsvUrl = getCsvExportUrl(targetSheetRawUrl);

                // Step 2: Fetch contents of Sheet Beta
                statusEl.innerText = "Connecting to Sheet Beta workspace contents...";
                const responseBeta = await fetch(targetSheetCsvUrl);
                if (!responseBeta.ok) throw new Error("Could not fetch operational Sheet Beta.");

                const csvTextBeta = await responseBeta.text();
                const matrixBeta = parseCSVData(csvTextBeta);

                // Step 3: Populate Application State
                parseSheetBeta(matrixBeta);

                // Step 4: Render UI Elements
                renderWorkspace();

                // Close loading cover
                document.getElementById("loader").classList.add("opacity-0", "pointer-events-none");
            } catch (err) {
                console.error("Pipeline breakdown:", err);
                statusEl.innerHTML = `<span class="text-rose-400 font-semibold">Failed to load public Google Sheets files:</span><br>${err.message}<br><br><span class="text-slate-400">Please make sure both sheets are shared as "Anyone with the link can view".</span>`;
                // Show fallback option
                document.getElementById("fallbackBtn").classList.remove("hidden");
            }
        }

        // Process matrix representation from Sheet Beta (Requirement 2)
        function parseSheetBeta(matrix) {
            // (1) Page title (B1 -> Row index 0, Col index 1)
            appState.title = matrix[0]?.[1] || "Default Sheet Workspace";

            // (1) Home link (A1 -> Row index 0, Col index 0)
            appState.homeUrl = matrix[0]?.[0] || "#";

            // (3e) Top bar column row contents (Row 2 -> Row index 1, Columns 0, 1, 2)
            appState.topBarContents = [
                matrix[1]?.[0] || "Header A",
                matrix[1]?.[1] || "Header B",
                matrix[1]?.[2] || "Header C"
            ];

            // (3b) Tab Button labels (Row 3 -> Row index 2, Columns 0, 1, 2)
            appState.tabLabels = [
                matrix[2]?.[0] || "Tab A",
                matrix[2]?.[1] || "Tab B",
                matrix[2]?.[2] || "Tab C"
            ];

            // (3d-i) Webpage Background color options (Row 4 -> Row index 3, Columns 0, 1, 2)
            appState.bgColors = [
                matrix[3]?.[0] || "#ffffff",
                matrix[3]?.[1] || "#f8fafc",
                matrix[3]?.[2] || "#f1f5f9"
            ];

            // (3d-ii) Column Font Colors (Row 5 -> Row index 4, Columns 0, 1, 2) - Defaults to Black if empty
            appState.fontColors = [
                matrix[4]?.[0] || "#000000",
                matrix[4]?.[1] || "#000000",
                matrix[4]?.[2] || "#000000"
            ];

            // Default Font Colors for second and third columns follow that of the first column (Requirement 5 / Font default color)
            appState.selectedFontColors = [
                appState.fontColors[0], // Column 1 starts with first choice
                appState.fontColors[0], // Column 2 follows Column 1 (Requirement)
                appState.fontColors[0]  // Column 3 follows Column 1 (Requirement)
            ];

            // (3d-iii) Font type choices: 
            // Col 1: A6, A7, A8 (Row 6, 7, 8 -> Row index 5, 6, 7; Col 0)
            // Col 2: B6, B7, B8 (Row 6, 7, 8 -> Row index 5, 6, 7; Col 1)
            // Col 3: C6, C7, C8 (Row 6, 7, 8 -> Row index 5, 6, 7; Col 2)
            appState.columnFonts = [
                [matrix[5]?.[0] || "ui-sans-serif", matrix[6]?.[0] || "ui-serif", matrix[7]?.[0] || "monospace"],
                [matrix[5]?.[1] || "ui-sans-serif", matrix[6]?.[1] || "ui-serif", matrix[7]?.[1] || "monospace"],
                [matrix[5]?.[2] || "ui-sans-serif", matrix[6]?.[2] || "ui-serif", matrix[7]?.[2] || "monospace"]
            ];

            // (3f) Text contents of table from Row 9 (Index 8) downwards
            appState.tableRows = [];
            for (let r = 8; r < matrix.length; r++) {
                if (matrix[r].some(val => val !== "")) {
                    appState.tableRows.push([
                        matrix[r][0] || "",
                        matrix[r][1] || "",
                        matrix[r][2] || ""
                    ]);
                }
            }
        }

        // Apply visual updates to DOM components
        function renderWorkspace() {
            // Document tab title and header title
            document.title = appState.title;
            document.getElementById("pageTitle").innerText = appState.title;

            // Direct typical home redirects
            document.getElementById("homeLink").href = appState.homeUrl;

            // Headers top bar names (Requirement 3a, 3e)
            document.getElementById("headerCol1").innerText = appState.topBarContents[0];
            document.getElementById("headerCol2").innerText = appState.topBarContents[1];
            document.getElementById("headerCol3").innerText = appState.topBarContents[2];

            // Tab Buttons name setup (Requirement 3b)
            document.getElementById("tabBtn1").innerText = appState.tabLabels[0];
            document.getElementById("tabBtn2").innerText = appState.tabLabels[1];
            document.getElementById("tabBtn3").innerText = appState.tabLabels[2];

            // Setup Customizer settings titles (removed "Settings" suffix as per user request)
            document.getElementById("settingTitle1").innerText = appState.tabLabels[0];
            document.getElementById("settingTitle2").innerText = appState.tabLabels[1];
            document.getElementById("settingTitle3").innerText = appState.tabLabels[2];

            // Setup custom background selector options (Requirement 3d-i)
            const bgContainer = document.getElementById("bgColorContainer");
            bgContainer.innerHTML = "";
            appState.bgColors.forEach((color, idx) => {
                const btn = document.createElement("button");
                btn.className = `w-10 h-10 rounded-full border-2 transition-transform hover:scale-105 shadow-sm relative ${idx === 0 ? 'border-indigo-600 scale-105' : 'border-slate-200'}`;
                btn.style.backgroundColor = color;
                btn.title = color;
                btn.onclick = () => {
                    document.documentElement.style.setProperty('--bg-color', color);
                    // Update border selected indicators
                    Array.from(bgContainer.children).forEach(b => b.className = "w-10 h-10 rounded-full border-2 border-slate-200 transition-transform hover:scale-105 shadow-sm");
                    btn.className = "w-10 h-10 rounded-full border-2 border-indigo-600 scale-105 transition-transform shadow-sm";
                };
                bgContainer.appendChild(btn);
            });
            // Initial Background Selection
            document.documentElement.style.setProperty('--bg-color', appState.bgColors[0]);

            // Set up Column Colors & Fonts Options
            setupSettingsOptions(1);
            setupSettingsOptions(2);
            setupSettingsOptions(3);

            // Synchronize Table layout items
            renderTableGrid();

            // Enforce initial default active status colors and styling layout
            for (let i = 1; i <= 3; i++) {
                const btn = document.getElementById(`tabBtn${i}`);
                if (appState.activeColumns.includes(i)) {
                    btn.className = "px-4 py-2 text-xs font-semibold rounded-lg transition-all shadow-sm bg-white text-slate-800 border border-slate-200/50 ring-1 ring-slate-100";
                } else {
                    btn.className = "px-4 py-2 text-xs font-semibold rounded-lg transition-all shadow-sm bg-slate-50 text-slate-400 hover:text-slate-600 border border-slate-200/40";
                }
            }
            syncColumnsDisplay();
        }

        // Populates selector menus under the slide-over settings panel
        function setupSettingsOptions(colNum) {
            const fontSelect = document.getElementById(`col${colNum}FontSelect`);
            const colorsContainer = document.getElementById(`col${colNum}Colors`);

            // 1. Setup fonts choices
            fontSelect.innerHTML = "";
            appState.columnFonts[colNum-1].forEach(fontName => {
                const opt = document.createElement("option");
                opt.value = fontName;
                opt.innerText = fontName;
                fontSelect.appendChild(opt);
            });
            // Apply initial setting
            updateFont(colNum, appState.columnFonts[colNum-1][0]);

            // 2. Setup colors selectors
            colorsContainer.innerHTML = "";
            appState.fontColors.forEach((hexColor, index) => {
                const btn = document.createElement("button");
                const isSelected = hexColor === appState.selectedFontColors[colNum-1];
                btn.className = `w-7 h-7 rounded-lg border transition-transform hover:scale-110 shadow-sm ${isSelected ? 'ring-2 ring-indigo-500 scale-105' : 'border-slate-200'}`;
                btn.style.backgroundColor = hexColor;
                btn.title = hexColor;
                btn.onclick = () => {
                    appState.selectedFontColors[colNum-1] = hexColor;
                    document.documentElement.style.setProperty(`--col${colNum}-color`, hexColor);
                    
                    // Re-draw selectors styling highlights
                    Array.from(colorsContainer.children).forEach((b, idx) => {
                        const isCurrent = appState.fontColors[idx] === hexColor;
                        b.className = `w-7 h-7 rounded-lg border transition-transform hover:scale-110 shadow-sm ${isCurrent ? 'ring-2 ring-indigo-500 scale-105' : 'border-slate-200'}`;
                    });
                };
                colorsContainer.appendChild(btn);
            });
            // Initial selection match setup
            document.documentElement.style.setProperty(`--col${colNum}-color`, appState.selectedFontColors[colNum-1]);
        }

        // Core table visual grid alignment builder (Requirement 3f)
        function renderTableGrid() {
            const body = document.getElementById("tableBody");
            body.innerHTML = "";

            if (appState.tableRows.length === 0) {
                body.innerHTML = `<div class="p-8 text-center text-slate-400 font-medium bg-white">No synchronized dataset found in Sheet Beta.</div>`;
                return;
            }

            // Create unified horizontal elements keeping vertical indexes always in complete sync
            appState.tableRows.forEach((rowCells, rowIndex) => {
                const rowDiv = document.createElement("div");
                rowDiv.className = "flex w-full divide-x divide-slate-100 sync-bg hover:bg-black/5 transition-colors border-b border-slate-100/60 last:border-b-0";
                rowDiv.dataset.rowIndex = rowIndex;

                rowCells.forEach((cellText, colIndex) => {
                    const cellDiv = document.createElement("div");
                    const colNum = colIndex + 1;
                    
                    // Assign classes dynamically for custom styling adjustments
                    cellDiv.id = `cell-r${rowIndex}-c${colNum}`;
                    cellDiv.className = `flex-1 p-4 md:p-6 transition-all duration-300 col-cell-${colNum} break-words leading-relaxed`;
                    cellDiv.innerText = cellText;

                    // If column is currently collapsed/hidden
                    if (!appState.activeColumns.includes(colNum)) {
                        cellDiv.style.display = "none";
                    }

                    rowDiv.appendChild(cellDiv);
                });

                body.appendChild(rowDiv);
            });
        }

        // Toggles Column visibility status (Requirement 3b, 3e, 3f)
        function toggleColumn(colNum) {
            const index = appState.activeColumns.indexOf(colNum);
            
            if (index > -1) {
                // Collapse action validation: At least 1 column must stay active
                if (appState.activeColumns.length <= 1) {
                    showAlert("At least one column must remain visible. To close this column, please open another first.");
                    return;
                }
                // Hide column elements
                appState.activeColumns.splice(index, 1);
                document.getElementById(`tabBtn${colNum}`).className = "px-4 py-2 text-xs font-semibold rounded-lg transition-all shadow-sm bg-slate-50 text-slate-400 hover:text-slate-600 border border-slate-200/40";
                
                // Hide header bar
                document.getElementById(`headerCol${colNum}`).style.display = "none";
            } else {
                // Show action validation: Maximum 2 columns can be active simultaneously
                if (appState.activeColumns.length >= 2) {
                    showAlert("Maximum limit reached. You can only view up to two columns at a time. Collapse another column to view this one.");
                    return;
                }
                // Show column elements
                appState.activeColumns.push(colNum);
                document.getElementById(`tabBtn${colNum}`).className = "px-4 py-2 text-xs font-semibold rounded-lg transition-all shadow-sm bg-white text-slate-800 border border-slate-200/50 ring-1 ring-slate-100";
                
                // Show header bar
                document.getElementById(`headerCol${colNum}`).style.display = "block";
            }

            // Sync visual active rows
            syncColumnsDisplay();
        }

        // Updates display state of cells depending on active columns (Requirement 3f)
        function syncColumnsDisplay() {
            for (let colNum = 1; colNum <= 3; colNum++) {
                const isActive = appState.activeColumns.includes(colNum);
                
                // Header Bar alignment
                const header = document.getElementById(`headerCol${colNum}`);
                header.style.display = isActive ? "block" : "none";

                // Every table element cell
                appState.tableRows.forEach((_, rowIndex) => {
                    const cell = document.getElementById(`cell-r${rowIndex}-c${colNum}`);
                    if (cell) {
                        cell.style.display = isActive ? "block" : "none";
                    }
                });
            }
        }

        // Apply custom font variables
        function updateFont(colNum, fontName) {
            document.documentElement.style.setProperty(`--col${colNum}-font`, fontName);
        }

        // Apply font size styles (Requirement 3d-iv)
        function updateFontSize(colNum, size) {
            document.getElementById(`col${colNum}SizeVal`).innerText = `${size}px`;
            document.documentElement.style.setProperty(`--col${colNum}-size`, `${size}px`);
        }

        // Custom alert controls (No native alerts rule)
        function showAlert(msg) {
            const overlay = document.getElementById("customAlert");
            const box = document.getElementById("customAlertBox");
            document.getElementById("customAlertText").innerText = msg;
            
            overlay.classList.remove("opacity-0", "pointer-events-none");
            box.classList.remove("scale-95");
            box.classList.add("scale-100");
        }

        // Close Alert Custom Modal Window
        function closeAlert() {
            const overlay = document.getElementById("customAlert");
            const box = document.getElementById("customAlertBox");
            
            overlay.classList.add("opacity-0", "pointer-events-none");
            box.classList.remove("scale-100");
            box.classList.add("scale-95");
        }

        // Settings slide-over display toggles
        function toggleSettings(open) {
            const overlay = document.getElementById("settingsOverlay");
            const panel = document.getElementById("settingsContent");
            
            if (open) {
                overlay.classList.remove("opacity-0", "pointer-events-none");
                panel.classList.remove("translate-x-full");
            } else {
                overlay.classList.add("opacity-0", "pointer-events-none");
                panel.classList.add("translate-x-full");
            }
        }

        // Close the settings panel when clicking anywhere on the overlay backdrop outside of the panel (Requirement click-outside-to-close)
        document.getElementById("settingsOverlay").addEventListener("click", (event) => {
            if (event.target === document.getElementById("settingsOverlay")) {
                toggleSettings(false);
            }
        });

        // Mock Sandbox Data simulation if fetching cannot bypass CORS or credentials
        function loadMockData() {
            const mockMatrix = [
                ["https://www.google.com", "Simulated Interactive Dashboard"], // Row 1 (A1: Home URL, B1: Title)
                ["Technical Overview Content", "Financial Indicators Content", "Growth Projection Content"], // Row 2 (Top row headers)
                ["Dev Specs", "Ledger Data", "Marketing Plans"], // Row 3 (A3, B3, C3: tab buttons text)
                ["#ffffff", "#f8fafc", "#e0f2fe"], // Row 4 (Background choices)
                ["#000000", "#1e3a8a", "#047857"], // Row 5 (Font color choices - defaulting to Black option for Col 1)
                ["ui-sans-serif", "ui-serif", "Courier New"], // Row 6 (Data A6/B6/C6 & font family choice 0)
                ["System Font B", "Georgia Style", "monospace"], // Row 7 (Data A7/B7/C7 & font family choice 1)
                ["Modern Sans C", "Garamond Serif", "Lucida Console"], // Row 8 (Data A8/B8/C8 & font family choice 2)
                
                // Content rows start here at index 8 (Row 9)
                ["Engine Architecture V3.1.2 is fully deployed and configured to support local dynamic rendering layouts.", "Total Assets reported increase to $1,429,000 as of the last audited quarter closure report.", "Ad campaign conversions grew by 22% over our targets, showcasing high visual performance."],
                ["API latencies were lowered by an average of 14ms across the load balancers following cache upgrades.", "Internal operating expenditures remain inside standard limits, tracking under initial allocations.", "Expansion strategies into localized regional nodes are greenlit for upcoming product iterations."],
                ["Security patches applied to database clusters successfully passed compliance verification.", "Operational net cash flow yields consistent progress aligned to year-over-year targets.", "User engagement score reached an all-time record on the unified platform experience."],
                ["Next sprint planning schedules prioritized resolving edge cases regarding responsive layouts.", "Strategic growth indicators project potential acceleration heading into the final financial quarter.", "Interactive media assets delivered an outstanding retention metric among targeted user cohorts."],
                ["Deployment pipelines have been optimized with modern containerization workflows.", "Venture development benchmarks verified standard operating metrics across active operational divisions.", "Brand consistency checks were validated to maintain high design standards across channels."]
            ];

            parseSheetBeta(mockMatrix);
            renderWorkspace();

            // Set active columns count initial default (for mock up, let's start with 2 active)
            appState.activeColumns = [1, 2];
            document.getElementById("tabBtn3").className = "px-4 py-2 text-xs font-semibold rounded-lg transition-all shadow-sm bg-slate-50 text-slate-400 hover:text-slate-600 border border-slate-200/40";
            syncColumnsDisplay();

            document.getElementById("loader").classList.add("opacity-0", "pointer-events-none");
        }

        // Run data pipeline automatically on load
        window.addEventListener("DOMContentLoaded", () => {
            runPipeline();
        });
    </script>
</body>
