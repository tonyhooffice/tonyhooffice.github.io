                <button id="tabBtn2" onclick="toggleColumn(2)" class="px-4 py-2 text-xs font-semibold rounded-lg transition-all shadow-sm bg-white text-slate-800 border border-slate-200/50 ring-1 ring-slate-100">
                    Tab B
