<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Collapsible Columns Workspace</title>
    <!-- Tailwind CSS for modern, premium utility styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom dynamic properties for settings customizability */
        :root {
            --bg-color: #f8fafc;
            
            --col1-color: #000000;
            --col1-font: ui-sans-serif, system-ui, sans-serif;
            --col1-size: 16px;
            
            --col2-color: #000000;
            --col2-font: ui-sans-serif, system-ui, sans-serif;
            --col2-size: 16px;
            
            --col3-color: #000000;
            --col3-font: ui-sans-serif, system-ui, sans-serif;
            --col3-size: 16px;
        }

        body {
            background-color: var(--bg-color);
            transition: background-color 0.3s ease;
        }

        /* Dynamically synchronized background class */
        .sync-bg {
            background-color: var(--bg-color) !important;
            transition: background-color 0.3s ease;
        }

        /* Set up dynamic fonts and colors for column elements */
        .col-cell-1 {
            color: var(--col1-color);
            font-family: var(--col1-font);
            font-size: var(--col1-size);
        }
        .col-cell-2 {
            color: var(--col2-color);
            font-family: var(--col2-font);
            font-size: var(--col2-size);
        }
        .col-cell-3 {
            color: var(--col3-color);
            font-family: var(--col3-font);
            font-size: var(--col3-size);
        }

        /* Custom scrollbar for premium touch and feel */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.05);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(0, 0, 0, 0.3);
        }
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden text-slate-800">

    <!-- Custom Notification/Alert Modal (Avoids native browser alert blockages) -->
    <div id="customAlert" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
        <div class="bg-white rounded-2xl p-6 max-w-sm w-full mx-4 shadow-2xl border border-slate-100 transform scale-95 transition-transform duration-300" id="customAlertBox">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-full bg-amber-50 flex items-center justify-center text-amber-500">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-slate-900">Constraint Rule</h3>
            </div>
            <p id="customAlertText" class="text-slate-600 mb-6 text-sm"></p>
            <button onclick="closeAlert()" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-medium py-2.5 px-4 rounded-xl transition-colors text-sm shadow-sm">
                Understand
            </button>
        </div>
    </div>

    <!-- Main Loading & Fallback Interface -->
    <div id="loader" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-slate-900 text-white p-6 transition-all duration-500">
        <div class="relative flex items-center justify-center mb-6">
            <div class="w-16 h-16 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
            <span class="absolute text-xs font-semibold text-indigo-400">CSV</span>
        </div>
        <h2 class="text-xl font-bold mb-2">Fetching Sheets Data</h2>
        <p id="loaderStatus" class="text-sm text-slate-400 text-center max-w-md">Resolving redirection link from the primary index registry...</p>
        
        <!-- Offline Mock Trigger in case of Sheet API failure -->
        <button id="fallbackBtn" onclick="loadMockData()" class="mt-8 px-5 py-2.5 bg-white/10 hover:bg-white/15 text-slate-300 hover:text-white rounded-xl text-sm font-medium transition-all border border-white/10 hidden">
            Load Mock Simulation Data
        </button>
    </div>

    <!-- Pinned Header Block (Requirement 3a & 3b with dynamic background color synchronization) -->
    <header class="sticky top-0 left-0 right-0 z-40 backdrop-blur-md border-b border-slate-200/80 shadow-sm flex-none sync-bg">
        
        <!-- Top Bar Row Content - Hidden as per user request to hide WebpageTitle and Active Columns Sync (Requirement 3) -->
        <div class="max-w-7xl mx-auto px-4 hidden">
            <div class="flex items-center justify-between py-4 border-b border-slate-100">
                <h1 id="pageTitle" class="text-lg font-extrabold text-slate-900 tracking-tight flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-indigo-600 animate-pulse"></span>
                    Loading Workspace...
                </h1>
                <span class="text-xs bg-slate-100/80 text-slate-600 font-semibold px-2.5 py-1 rounded-full border border-slate-200">Active Columns Sync</span>
            </div>
        </div>

        <!-- Sticky Collapsible Columns Heading Row (Requirement 3a, 3e, with header colors and background following the dynamic color states) -->
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex w-full divide-x divide-slate-100 border-b border-slate-100 text-xs font-bold uppercase tracking-wider sync-bg">
                <div id="headerCol1" class="flex-1 p-4 transition-all duration-300 overflow-hidden col-cell-1">Column 1 Contents</div>
                <div id="headerCol2" class="flex-1 p-4 transition-all duration-300 overflow-hidden col-cell-2">Column 2 Contents</div>
                <div id="headerCol3" class="flex-1 p-4 transition-all duration-300 overflow-hidden col-cell-3" style="display: none;">Column 3 Contents</div>
            </div>
        </div>

        <!-- Panel Bar Toolbar: Tabs (Left) & Controls (Right) (Requirement 3b, 3c) -->
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
            <!-- Tabs container (Left) -->
            <div class="flex items-center gap-1.5 bg-slate-100/60 p-1 rounded-xl">
